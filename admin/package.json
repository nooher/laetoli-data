{
  "name": "@laetoli/admin",
  "version": "0.1.0",
  "description": "Laetoli Data — sovereign admin API (Admin Studio backend). Schema introspection, SQL console, auth/storage/RLS management. Gated by ADMIN_API_KEY; connects to Postgres as a BYPASSRLS role.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
