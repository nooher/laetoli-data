# Daftari — point the SDK at YOUR Laetoli Data node.
# Copy to .env.local (Vite auto-loads it). Vite only exposes VITE_-prefixed vars.

# The single public endpoint your node serves (Caddy). Local dev default:
VITE_LAETOLI_DATA_URL=http://localhost:8088

# Anonymous apikey, ONLY if your node enforces one (REQUIRE_API_KEY=true or a
# locked-down deploy). Leave blank for the standard JWT flow on a local node.
VITE_LAETOLI_ANON_KEY=
