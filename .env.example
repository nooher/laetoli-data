# Laetoli Data — environment. Copy to .env and set strong secrets.

# PostgreSQL
POSTGRES_USER=laetoli
# REQUIRED — set in your own .env (never commit it). Generate: openssl rand -base64 24
POSTGRES_PASSWORD=
POSTGRES_DB=laetoli

# Shared HS256 secret — MUST be identical for PostgREST and the auth service.
# REQUIRED, >= 32 chars. Generate: openssl rand -base64 48
JWT_SECRET=

# JWT lifetime (seconds) for issued tokens
JWT_EXPIRY=3600

# PostgREST
PGRST_DB_ANON_ROLE=anon
PGRST_DB_SCHEMAS=public

# Public base URL (what clients hit, via Caddy). For local dev: http://localhost:8088
LAETOLI_DATA_URL=http://localhost:8088

# Caddy site address. Local/Pi: ":80" (plain HTTP, reached via CADDY_HTTP).
# Production: set to your domain (e.g. data.example.tz) for AUTOMATIC HTTPS.
# (Must be non-empty — Caddy treats an empty value as a keyless/global block.)
CADDY_DOMAIN=:80

# --- CORS (browser cross-origin policy at the edge) --------------------------
# DEFAULT (both unset/commented): permissive `Access-Control-Allow-Origin: *`.
# Fine for local dev and the @laetoli/data SDK from anywhere; NOT for a public
# deployment. To LOCK DOWN for production:
#   1. Leave CORS_ALLOWED_ORIGINS empty (so the "*" fallback is overridable), AND
#   2. Set CORS_ALLOWED_ORIGINS_REGEXP to an ANCHORED alternation of your app
#      origins. Matching origins are reflected back with `Vary: Origin`;
#      everything else gets no Allow-Origin (browser blocks the read).
# Turn a comma list "https://app.example.tz,https://admin.example.tz" into:
#   ^(https://app\.example\.tz|https://admin\.example\.tz)$
# (escape the dots; no trailing slash on origins). See SECURITY.md "CORS".
# CORS_ALLOWED_ORIGINS=
# CORS_ALLOWED_ORIGINS_REGEXP=^(https://app\.example\.tz|https://admin\.example\.tz)$

# --- Edge rate limiting (Caddy gateway) --------------------------------------
# Per-IP throttling at the edge for the public API routes. ONLY effective on a
# Caddy image built WITH the rate_limit plugin (the base caddy:2-alpine does not
# include it — see SECURITY.md for the xcaddy build). The auth service's own
# per-IP limiter is always on as the guaranteed floor. Defaults are gentle:
# ~RATE_LIMIT_RPS req/s sustained, bursting to RATE_LIMIT_BURST per minute; 429
# on abuse. Raise for trusted internal use, lower to tighten.
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=120

# Object storage (filesystem-backed). STORAGE_ROOT is the in-container path
# backed by the storage_data volume; bytes live there, metadata in Postgres.
STORAGE_ROOT=/data/storage
STORAGE_MAX_UPLOAD_BYTES=52428800

# Realtime (WebSocket fan-out of Postgres LISTEN/NOTIFY changes).
REALTIME_PORT=9997
REALTIME_CHANNEL=laetoli_realtime
# Owner-scoped (per-subscriber) realtime filtering. Comma-separated, ordered
# column names treated as a row's owner; the first present in the changed row
# wins and the change is delivered ONLY to the WS subscriber whose JWT `sub`
# matches it (service/laetoli_admin roles bypass). Tables with none of these
# columns broadcast to all subscribers (back-compat). Default: user_id,owner
# REALTIME_OWNER_COLUMNS=user_id,owner
# Broadcast + presence (ephemeral, DB-independent) ride the SAME channels/WS.
# They are channel-membership-based with NO owner-RLS gate: every subscriber of
# a channel sees every broadcast payload and presence state — do NOT put secrets
# in them. When true, a client's own broadcasts are also echoed back to itself
# (default false → relay to OTHER subscribers only).
# REALTIME_BROADCAST_SELF=false

# Per-role DB passwords (optional). The storage + realtime + admin services reuse
# POSTGRES_PASSWORD by default; uncomment to give each its own secret.
# LAETOLI_STORAGE_PASSWORD=
# LAETOLI_REALTIME_PASSWORD=
# LAETOLI_ADMIN_PASSWORD=

# Admin API / Studio — the sovereign "service role key" (keys-to-the-kingdom: the
# admin service connects with BYPASSRLS and can read/write/DROP anything).
# REQUIRED to run the admin service; it refuses to start if unset. >= 24 chars.
# Generate: openssl rand -base64 36
ADMIN_API_KEY=

# Edge functions runner (operator-provided serverless functions over HTTP).
FUNCTION_TIMEOUT_MS=10000

# Automated backups (@laetoli/backup service, port 9994).
# 5-field cron (preferred). BACKUP_KEEP = how many dumps (+ storage archives) to retain.
BACKUP_CRON=0 3 * * *
BACKUP_KEEP=14
# Off-device durability (all optional, fail-soft — leave blank to disable):
#   BACKUP_MIRROR_DIR   copy each backup to a SECOND path inside the container
#                       (mount a USB drive at e.g. /mirror to use this).
#   BACKUP_OFFSITE_CMD  shell push run per artifact after a successful dump;
#                       {file}/{name} are substituted, e.g.
#                       "rclone copy {file} remote:laetoli".
#   BACKUP_STORAGE_DIR  archive the object-storage volume (tar.gz) each run; the
#                       backup service mounts storage_data read-only at /storage,
#                       so set this to /storage to enable.
BACKUP_MIRROR_DIR=
BACKUP_OFFSITE_CMD=
BACKUP_STORAGE_DIR=

# Multi-tenant API-key enforcement on storage + functions. OFF by default — the
# guard is a no-op until set true (then requests need a valid `apikey`, minted in
# the Studio "API Keys" screen / admin API). Leave false for the standard JWT flow.
REQUIRE_API_KEY=false

# --- Vectors / AI-native (pgvector) ------------------------------------------
# No runtime env is required for vector search. The `documents.embedding`
# dimension is set in SQL (db/migrations/0005_vectors.sql, default 384), NOT
# here. This knob is DOC-ONLY: it records which embedding width your deployment
# uses so operators/agents stay in sync. Changing it does NOT alter the schema —
# you must also edit the column type + match_documents() and recreate the index.
# See docs/VECTORS.md. Requires the `pgvector/pgvector:pg16` db image.
# VECTOR_DIM=384
